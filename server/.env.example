# Copy to .env and fill in. No value here is a real secret placeholder -
# every key the server reads is documented below.

# --- Runtime ---
# development | production | test
NODE_ENV=
# API listen port (default 3100)
PORT=

# --- Database ---
# Postgres connection string for the canquery database (catalog mirror +
# ingestion state + the store schema with ingested tables).
# Legacy prod .env may still use OPENCANADA_DATABASE_URL - pool.js accepts both.
CANQUERY_DATABASE_URL=
# API/default pool defaults: 10 connections (minimum 4 for worker coordination),
# 5s acquisition, 30s PostgreSQL statement timeout, and 35s client-side query
# timeout. The separate COPY/DDL pool stays small (2 connections) and uses
# generous finite per-statement/client limits (30/31 minutes).
DB_POOL_MAX=
DB_LONG_POOL_MAX=
DB_CONNECTION_TIMEOUT_MS=
DB_IDLE_TIMEOUT_MS=
DB_STATEMENT_TIMEOUT_MS=
DB_QUERY_TIMEOUT_MS=
DB_LONG_STATEMENT_TIMEOUT_MS=
DB_LONG_QUERY_TIMEOUT_MS=

# --- Upstream CKAN (open.canada.ca) ---
# Default: https://open.canada.ca/data/api/3/action
CKAN_BASE_URL=
# Polite identifying User-Agent, e.g. canquery/1.0 (contact email)
CKAN_USER_AGENT=

# --- CORS ---
# Comma-separated list of origins allowed to call the API with credentials.
# localhost:5173 is added automatically outside production.
CORS_ALLOWED_ORIGINS=

# --- Ingestion caps (load-bearing safety rails; defaults in parentheses) ---
# Max CSV download size in MB (50)
MAX_FILE_MB=
# Max Excel (XLSX/XLS) download size in MB (20) - smaller because workbook
# expansion is memory-intensive even inside the isolated converter process.
MAX_XLSX_MB=
# Max rows per ingested resource (1000000)
MAX_ROWS=
# Max columns per ingested resource (120)
MAX_COLS=
# Days of query_log history kept by the prune cron (30)
QUERY_LOG_RETENTION_DAYS=
# Total store schema disk budget in GB; evict-store.js enforces it (15)
STORE_BUDGET_GB=
# Pre-COPY logical headroom and source-to-relation estimate (256 MB, 2x).
STORE_INGEST_HEADROOM_MB=
STORE_SIZE_RESERVE_MULTIPLIER=
# Required in production: an app-readable host path on the same filesystem as
# PostgreSQL's store data. It
# can be a readable parent/mount anchor (for example /var/lib for a Docker
# volume whose own 0700 directory the app cannot traverse). Worker startup and
# every ingest fail closed if the path cannot be checked or cannot
# preserve STORE_MIN_FREE_GB (2) plus the estimated new relation size.
STORE_DATA_PATH=
STORE_MIN_FREE_GB=
# Emergency free-space floor retained on TMPDIR while downloading/converting
# resources (512 MB).
TMP_MIN_FREE_MB=
# Excel conversion runs in a child process with a heap/time ceiling (384 MB,
# 120000 ms) in addition to the worker unit's cgroup memory limit.
EXCEL_CONVERT_MEMORY_MB=
EXCEL_CONVERT_TIMEOUT_MS=
# XLSX ZIP preflight limits (5000 entries, 16 MB central directory, 256 MB
# aggregate expansion, 128 MB per entry, 64 MB shared strings, 16 MB styles,
# 100x maximum compression ratio).
XLSX_MAX_ENTRIES=
XLSX_MAX_CENTRAL_DIRECTORY_MB=
XLSX_MAX_UNCOMPRESSED_MB=
XLSX_MAX_ENTRY_MB=
XLSX_MAX_SHARED_STRINGS_MB=
XLSX_MAX_STYLES_MB=
XLSX_MAX_COMPRESSION_RATIO=
# Worker poll interval in ms when the queue is empty (3000)
INGEST_POLL_MS=
# Active-job lease heartbeat in ms (15000)
INGEST_HEARTBEAT_MS=
# Abort an ingest download if no bytes arrive within this many ms - stops a
# stalled upstream from wedging the worker (60000)
INGEST_STALL_TIMEOUT_MS=

# --- Public query workload limits ---
# Maximum local query offset (10000); use filters/keyset-style refinement for
# deeper navigation. CSV exports have a 10000-row hard cap and local rows are
# fetched in 500-row batches.
MAX_QUERY_OFFSET=
EXPORT_MAX_ROWS=

# --- Catalogue synchronization safety ---
# Incremental sync filters to a five-minute inclusive overlap and reports an
# incomplete run instead of advancing its checkpoint at this page ceiling
# (1000 pages by default, larger than the full current catalogue).
INCREMENTAL_SYNC_OVERLAP_SECONDS=
INCREMENTAL_SYNC_MAX_PAGES=
# A full sync refuses a deletion sweep if more than this fraction of the local
# catalogue disappeared (0.1 = 10%).
FULL_SYNC_MAX_DELETE_FRACTION=
