# Copy to .env and fill in. No value here is a real secret placeholder -
# every key the server reads is documented below.

# --- Runtime ---
# development | production | test
NODE_ENV=
# API listen port (production uses 3100; 3000/3456/3457 are taken on <platform>-01)
PORT=

# --- Database ---
# Postgres connection string for the opencanada database (catalog mirror +
# ingestion state + the store schema with ingested tables)
OPENCANADA_DATABASE_URL=

# --- Upstream CKAN (open.canada.ca) ---
# Default: https://open.canada.ca/data/api/3/action
CKAN_BASE_URL=
# Polite identifying User-Agent, e.g. opencanada/1.0 (contact email)
CKAN_USER_AGENT=

# --- CORS ---
# Comma-separated list of origins allowed to call the API with credentials.
# localhost:5173 is added automatically outside production.
CORS_ALLOWED_ORIGINS=

# --- Ingestion caps (load-bearing safety rails; defaults in parentheses) ---
# Max CSV download size in MB (50)
MAX_FILE_MB=
# Max rows per ingested resource (1000000)
MAX_ROWS=
# Max columns per ingested resource (120)
MAX_COLS=
# Total store schema disk budget in GB; evict-store.js enforces it (15)
STORE_BUDGET_GB=
# Worker poll interval in ms when the queue is empty (3000)
INGEST_POLL_MS=
